// ===================================
// FIRESTORE RULES - CLIENTE GENÉRICO
// ===================================
// 
// Estas reglas son GENÉRICAS para cualquier cliente
// NO incluyen sufijos de ciudad (ej: _cordoba, _mardelplata)
// 
// Úsalas tal cual en tu Firebase Project del cliente
//

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== HELPERS =====
    
    // Usuario autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Es operador (en patrulla)
    function isOperador() {
      return isAuthenticated() && 
             request.auth.token.role == 'operador';
    }
    
    // Es admin
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.role == 'admin';
    }
    
    // Es operador o admin
    function isOperadorOrAdmin() {
      return isOperador() || isAdmin();
    }


    // ===== PATRULLAS (ubicación en tiempo real) =====
    
    match /patrullas/{patrolId} {
      // Leer: cualquier usuario autenticado
      allow read: if isAuthenticated();
      
      // Escribir: solo operadores y admins
      allow write: if isOperadorOrAdmin();
      
      // Historial de GPS
      match /gps_history/{entry} {
        allow read: if isAuthenticated();
        allow write: if isOperadorOrAdmin();
      }
    }


    // ===== CHAT EN TIEMPO REAL =====
    
    match /chat/{document=**} {
      // Leer: cualquier usuario autenticado
      allow read: if isAuthenticated();
      
      // Escribir: cualquier usuario autenticado
      allow write: if isAuthenticated();
      
      // Borrar: solo operadores y admins
      allow delete: if isOperadorOrAdmin();
    }


    // ===== MENSAJES =====
    
    match /messages/{messageId} {
      // Leer: cualquier usuario autenticado
      allow read: if isAuthenticated();
      
      // Crear: cualquier usuario autenticado
      allow create: if isAuthenticated() &&
                       request.resource.data.timestamp == request.time;
      
      // Actualizar: propietario o admin
      allow update: if isAuthenticated() &&
                       (resource.data.userId == request.auth.uid || isAdmin());
      
      // Borrar: propietario o admin
      allow delete: if isAuthenticated() &&
                       (resource.data.userId == request.auth.uid || isAdmin());
    }


    // ===== WEBRTC (Señalización de video/audio) =====
    
    match /webrtc/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }


    // ===== USERS (Perfil de usuarios) =====
    
    match /users/{userId} {
      // Leer: cualquier usuario autenticado
      allow read: if isAuthenticated();
      
      // Crear: el mismo usuario
      allow create: if isAuthenticated() &&
                       request.auth.uid == userId;
      
      // Actualizar: el mismo usuario o admin
      allow update: if isAuthenticated() &&
                       (request.auth.uid == userId || isAdmin());
      
      // Borrar: solo admin
      allow delete: if isAdmin();
    }


    // ===== ROBOS (Datos de crímenes) =====
    
    match /robos/{document=**} {
      // Leer: solo operadores y admins
      allow read: if isOperadorOrAdmin();
      
      // Escribir: solo admins (crear, actualizar)
      allow write: if isAdmin();
    }


    // ===== ALERTAS =====
    
    match /alertas/{document=**} {
      // Leer: cualquier usuario autenticado
      allow read: if isAuthenticated();
      
      // Escribir: solo admin
      allow write: if isAdmin();
    }


    // ===== CONFIGURACIÓN =====
    
    match /config/{document=**} {
      // Leer: cualquier usuario autenticado
      allow read: if isAuthenticated();
      
      // Escribir: solo admin
      allow write: if isAdmin();
    }


    // ===== AUDIT LOGS =====
    
    match /audit_logs/{document=**} {
      // Leer: solo admin
      allow read: if isAdmin();
      
      // Escribir: cualquier usuario autenticado (para logging)
      allow write: if isAuthenticated();
    }


    // ===== CAMADAS DE DATOS (Siniestros, cámaras, etc) =====
    
    match /siniestros/{document=**} {
      allow read: if isAuthenticated();
    }

    match /cameras/{document=**} {
      allow read: if isAuthenticated();
    }

    match /private_cameras/{document=**} {
      allow read: if isAuthenticated();
    }

    match /semaforos/{document=**} {
      allow read: if isAuthenticated();
    }

    match /barrios/{document=**} {
      allow read: if isAuthenticated();
    }

    match /colegios/{document=**} {
      allow read: if isAuthenticated();
    }

    match /corredores_escolares/{document=**} {
      allow read: if isAuthenticated();
    }

    match /zones/{document=**} {
      allow read: if isAuthenticated();
    }


    // ===== DEFAULT: DENY TODOS =====
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
