rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================
    // HELPERS
    // ============================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
             (request.auth.token.rol == 'super_admin' || 
              request.auth.token.rol == 'admin' ||
              request.auth.token.role == 'admin' ||
              request.auth.token.email == 'admin@trafico-map.com' ||
              request.auth.email == 'admin@trafico-map.com');
    }
    
    function isClienteUser() {
      return isAuthenticated() && 
             request.auth.token.clienteId != null;
    }
    
    function getUserClienteId() {
      return request.auth.token.clienteId;
    }

    
    // ============================
    // COLECCIÓN: admins
    // ============================
    // Solo super_admins pueden leer/escribir
    match /admins/{doc=**} {
      allow read, write: if isSuperAdmin();
    }
    
    // ============================
    // COLECCIÓN: usuarios
    // ============================
    match /usuarios/{uid} {
      // El usuario puede leer su propio documento
      allow read: if request.auth.uid == uid;
      // Solo super_admin puede crear/actualizar usuarios
      allow create, update, delete: if isSuperAdmin();
    }
    
    // ============================
    // COLECCIÓN: clientes (MULTI-TENANT)
    // ============================
    match /clientes/{clienteId} {
      // Para lectura:
      // - Permitir lectura a TODOS para validación de email/password en login
      // - Admin/Super Admin: acceso completo
      // - Clientes autenticados (con clienteId): pueden leer su propio cliente
      allow read: if true; // Permitir lectura pública para login
      allow write: if isSuperAdmin();
      
      // Config del cliente
      match /config/{doc=**} {
        allow read: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow write: if isSuperAdmin();
      }
      
      // Datos del cliente: cámaras, siniestros, etc.
      // Nombres en plural (camaras, cameras son aliases)
      // NOTA: Permitir lectura a ANYBODY porque la autenticación se valida en JavaScript
      // y no hay información sensible en lectura (los datos públicos del cliente)
      match /camaras/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }

      match /cameras/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }

      match /cameras_privadas/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }

      match /camaras_privadas/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }
      
      match /siniestros/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }

      match /barrios/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }
      
      match /semaforos/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }
      
      match /robos/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }
      
      match /escuelas/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }

      match /colegios/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }
      
      match /corredores/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }

      match /flujo/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }
      
      match /lineas/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }
      
      match /operadores/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }
      
      match /patrullas/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }
      
      match /listas/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }
      
      match /usuarios_clientes/{doc=**} {
        allow read: if true; // Lectura pública (autenticación en JS)
        allow write: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
        allow delete: if isSuperAdmin() || (isClienteUser() && getUserClienteId() == clienteId);
      }
    }
    
    // ============================
    // COLECCIÓN: operaciones (global)
    // ============================
    // Logs de operaciones, acceso solo para admins
    match /operaciones/{doc=**} {
      allow read, write: if isSuperAdmin();
    }

    // ============================
    // COLECCIÓN: subscripciones (global)
    // ============================
    match /subscripciones/{doc=**} {
      allow read, write: if isSuperAdmin();
    }

    // ============================
    // COLECCIÓN: billing (global)
    // ============================
    match /billing/{doc=**} {
      allow read, write: if isSuperAdmin();
    }

    // ============================
    // COLECCIÓN: pagos (global)
    // ============================
    match /pagos/{doc=**} {
      allow read, write: if isSuperAdmin();
    }
    
    // ============================
    // DEFAULT: DENY
    // ============================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
