rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== FUNCIONES DE AUTENTICACIÓN Y ROLES ==========
    function isAuthenticated() {
      return request.auth != null;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isOperador() {
      return userRole() == 'operador';
    }

    function isPatrulla() {
      return userRole() == 'patrulla';
    }

    function getUserEmail() {
      return request.auth.token.email;
    }

    function isOperadorOrAdmin() {
      return isOperador() || isAdmin();
    }

    function isPatullaOrAdmin() {
      return isPatrulla() || isAdmin();
    }

    // ========== USERS - Solo admins ==========
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ========== PATRULLAS MAR DEL PLATA (con y sin guiones) ==========
    match /patrullas_mar-del-plata/{patrolId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      match /gps_history/{entry} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    match /patrullas_mardelplata/{patrolId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      match /gps_history/{entry} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // ========== PATRULLAS CORDOBA ==========
    match /patrullas_cordoba/{patrolId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      match /gps_history/{entry} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // ========== CHAT MAR DEL PLATA (con y sin guiones) ==========
    match /chat_mar-del-plata/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isOperadorOrAdmin();
    }

    match /chat_mardelplata/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isOperadorOrAdmin();
    }

    // ========== CHAT CORDOBA ==========
    match /chat_cordoba/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow delete: if isOperadorOrAdmin();
    }

    // ========== MESSAGES MAR DEL PLATA Y CORDOBA ==========
    match /messages_mar-del-plata/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isOperadorOrAdmin();
    }

    match /messages_mardelplata/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isOperadorOrAdmin();
    }

    match /messages_cordoba/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isOperadorOrAdmin();
    }

    // ========== WEBRTC MAR DEL PLATA (con y sin guiones) ==========
    match /webrtc_mar-del-plata/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /webrtc_mardelplata/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ========== WEBRTC CORDOBA ==========
    match /webrtc_cordoba/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ========== ROBOS (Siniestros) ==========
    match /robos/{document=**} {
      allow read: if isOperadorOrAdmin();
      allow write: if isAdmin();
    }

    // ========== AUDIT LOGS ==========
    match /audit_logs/{document=**} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    // ========== DEFAULT: DENY ==========
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
