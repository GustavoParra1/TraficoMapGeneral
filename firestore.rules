rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== AUTENTICACIÓN ==========
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // ========== USERS ==========
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ========== PATRULLAS MAR DEL PLATA - Permitir testing sin autenticación ==========
    match /patrullas_mar-del-plata/{patrolId} {
      allow read: if true;
      allow write: if true;
      match /gps_history/{entry} {
        allow read: if true;
        allow write: if true;
      }
    }

    // ========== PATRULLAS SAN MARTIN DEL MAR - Permitir testing sin autenticación ==========
    match /patrullas_san-martin-del-mar/{patrolId} {
      allow read: if true;
      allow write: if true;
      match /gps_history/{entry} {
        allow read: if true;
        allow write: if true;
      }
    }

    // ========== PATRULLAS CORDOBA - Permitir testing sin autenticación ==========
    match /patrullas_cordoba/{patrolId} {
      allow read: if true;
      allow write: if true;
      match /gps_history/{entry} {
        allow read: if true;
        allow write: if true;
      }
    }

    // ========== CHAT MAR DEL PLATA ==========
    match /chat_mar-del-plata/{patrolId} {
      allow read: if true;
      allow write: if true;
      match /messages/{messageId} {
        allow read: if true;
        allow write: if true;
        allow delete: if true;
      }
    }

    // ========== CHAT SAN MARTIN DEL MAR ==========
    match /chat_san-martin-del-mar/{patrolId} {
      allow read: if true;
      allow write: if true;
      match /messages/{messageId} {
        allow read: if true;
        allow write: if true;
        allow delete: if true;
      }
    }

    // ========== CHAT CORDOBA ==========
    match /chat_cordoba/{patrolId} {
      allow read: if true;
      allow write: if true;
      match /messages/{messageId} {
        allow read: if true;
        allow write: if true;
        allow delete: if true;
      }
    }

    // ========== WEBRTC MAR DEL PLATA ==========
    match /webrtc_mar-del-plata/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // ========== WEBRTC SAN MARTIN DEL MAR ==========
    match /webrtc_san-martin-del-mar/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // ========== WEBRTC CORDOBA ==========
    match /webrtc_cordoba/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // ========== ROBOS (Siniestros) ==========
    match /robos/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ========== AUDIT LOGS ==========
    match /audit_logs/{document=**} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    // ========== DEFAULT: DENY ==========
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
