rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== FUNCIONES DE AUTENTICACIÓN Y ROLES ==========
    function isAuthenticated() {
      return request.auth != null;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isOperador() {
      return userRole() == 'operador';
    }

    function isPatrulla() {
      return userRole() == 'patrulla';
    }

    function getUserEmail() {
      return request.auth.token.email;
    }

    // Solo patrullas o admins
    function isOperadorOrAdmin() {
      return isOperador() || isAdmin();
    }

    // Solo patrullas o admins
    function isPatullaOrAdmin() {
      return isPatrulla() || isAdmin();
    }

    // ========== USERS - Solo admins ==========
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ========== PATRULLAS MAR DEL PLATA ==========
    match /patrullas_mar-del-plata/{patrolId} {
      allow read: if isAuthenticated();
      // Patrullas pueden actualizar su propia posición
      allow write: if isPatullaOrAdmin();
      match /gps_history/{entry} {
        allow read: if isAuthenticated();
        allow write: if isPatullaOrAdmin();
      }
    }

    // ========== PATRULLAS SAN MARTIN DEL MAR ==========
    match /patrullas_san-martin-del-mar/{patrolId} {
      allow read: if isAuthenticated();
      allow write: if isPatullaOrAdmin();
      match /gps_history/{entry} {
        allow read: if isAuthenticated();
        allow write: if isPatullaOrAdmin();
      }
    }

    // ========== PATRULLAS CORDOBA ==========
    match /patrullas_cordoba/{patrolId} {
      allow read: if isAuthenticated();
      allow write: if isPatullaOrAdmin();
      match /gps_history/{entry} {
        allow read: if isAuthenticated();
        allow write: if isPatullaOrAdmin();
      }
    }

    // ========== CHAT MAR DEL PLATA ==========
    match /chat_mar-del-plata/{patrolId} {
      allow read: if isAuthenticated();
      allow write: if isPatullaOrAdmin();
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow write: if isPatullaOrAdmin();
        allow delete: if isOperadorOrAdmin();
      }
    }

    // ========== CHAT SAN MARTIN DEL MAR ==========
    match /chat_san-martin-del-mar/{patrolId} {
      allow read: if isAuthenticated();
      allow write: if isPatullaOrAdmin();
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow write: if isPatullaOrAdmin();
        allow delete: if isOperadorOrAdmin();
      }
    }

    // ========== CHAT CORDOBA ==========
    match /chat_cordoba/{patrolId} {
      allow read: if isAuthenticated();
      allow write: if isPatullaOrAdmin();
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow write: if isPatullaOrAdmin();
        allow delete: if isOperadorOrAdmin();
      }
    }

    // ========== MESSAGES - Nueva colección centralizada ==========
    match /messages_{municipio}/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isOperadorOrAdmin();
    }

    // ========== WEBRTC MAR DEL PLATA ==========
    match /webrtc_mar-del-plata/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ========== WEBRTC SAN MARTIN DEL MAR ==========
    match /webrtc_san-martin-del-mar/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ========== WEBRTC CORDOBA ==========
    match /webrtc_cordoba/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ========== ROBOS (Siniestros) ==========
    match /robos/{document=**} {
      allow read: if isOperadorOrAdmin();
      allow write: if isAdmin();
    }

    // ========== AUDIT LOGS ==========
    match /audit_logs/{document=**} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    // ========== DEFAULT: DENY ==========
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
